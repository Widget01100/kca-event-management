    }
});

// Database Admin View (Simplified)
app.get('/api/admin/database', async (req, res) => {
    try {
        // Simple queries that won't fail
        const events = await new Promise((resolve, reject) => {
            db.all('SELECT * FROM events', [], (err, rows) => {
                if (err) reject(err);
                else resolve(rows || []);
            });
        });
        
        const users = await new Promise((resolve, reject) => {
            db.all('SELECT id, email, first_name, last_name, role, is_active FROM users', [], (err, rows) => {
                if (err) reject(err);
                else resolve(rows || []);
            });
        });
        
        const categories = await new Promise((resolve, reject) => {
            db.all('SELECT * FROM categories', [], (err, rows) => {
                if (err) reject(err);
                else resolve(rows || []);
            });
        });
        
        let html = `
        <!DOCTYPE html>
        <html>
        <head>
            <title>KCA Database Admin</title>
            <style>
                body { font-family: Arial; background: #f5f5f5; padding: 20px; }
                h1 { color: #1e3c72; }
                .card { background: white; border-radius: 10px; padding: 20px; margin: 20px 0; }
                table { width: 100%; border-collapse: collapse; }
                th { background: #1e3c72; color: white; padding: 10px; }
                td { padding: 10px; border-bottom: 1px solid #ddd; }
                .badge { background: #7e22ce; color: white; padding: 3px 10px; border-radius: 15px; }
            </style>
        </head>
        <body>
            <h1>🎓 KCA University Database</h1>
            <div class="card">
                <h2>Events (${events.length})</h2>
                <table>
                    <tr><th>ID</th><th>Title</th><th>Date</th><th>Venue</th></tr>`;
        
        events.forEach(e => {
            html += `<tr><td>${e.id}</td><td>${e.title}</td><td>${e.date}</td><td>${e.venue}</td></tr>`;
        });
        
        html += `</table></div>
            <div class="card">
                <h2>Users (${users.length})</h2>
                <table>
                    <tr><th>Email</th><th>Name</th><th>Role</th></tr>`;
        
        users.forEach(u => {
            html += `<tr><td>${u.email}</td><td>${u.first_name} ${u.last_name}</td><td><span class="badge">${u.role}</span></td></tr>`;
        });
        
        html += `</table></div>
            <div class="card">
                <h2>Categories (${categories.length})</h2>
                <table>
                    <tr><th>Name</th><th>Description</th></tr>`;
        
        categories.forEach(c => {
            html += `<tr><td><span class="badge">${c.name}</span></td><td>${c.description || ''}</td></tr>`;
        });
        
        html += `</table></div>
            <p>Generated at ${new Date().toLocaleString()}</p>
        </body></html>`;
        
        res.send(html);
    } catch (error) {
        res.status(500).send(`Error: ${error.message}`);
    }
});

