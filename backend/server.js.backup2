// Get Attendance Report
app.get('/api/events/:id/attendance', async (req, res) => {
    try {
        const user = getCurrentUser(req);
        if (user.role === 'student' || !user.id) {
            return res.status(403).json({ success: false, message: "Access denied" });
        }
        const report = await database.getAttendanceReport(req.params.id);
        const event = await database.getEventById(req.params.id);
        
        const summary = {
            total_registrations: report.length,
            attended: report.filter(r => r.attendance_marked).length,
            not_attended: report.filter(r => !r.attendance_marked).length,
            attendance_rate: report.length ? 
                Math.round((report.filter(r => r.attendance_marked).length / report.length) * 100) : 0
        };
        
        res.json({ success: true, event, summary, data: report });
    } catch (error) {
        res.status(500).json({ success: false, error: error.message });
    }
});

